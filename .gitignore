# 런타임 상태 파일
.state.json
.sound.pid
.last_update_check
*.log
logs/

# 빌드 산출물 (배포 tarball - cromaizing.com에 직접 업로드)
dist/

# Placeholder 사운드 (저작권 회피 - install 시 macOS 시스템 사운드에서 생성)
packs/cromaiping_default/sounds/*.wav
packs/cromaiping_default/sounds/*.aiff

# 음원 파일 (기본 제외 — 신규 팩은 라이선스 검증 후 명시적 opt-in)
packs/*/sounds/*.mp3
packs/*/sounds/*.wav
packs/*/sounds/*.ogg
packs/*/sounds/*.aiff

# 라이선스 OK 확인된 팩들 (명시적 포함)
!packs/karina/sounds/*.mp3
!packs/karina/sounds/*.wav

# 팩 소스 폴더 (사용자가 작업 중인 원본 음원, 루트 한정)
/Karina/
*.source/

# macOS
.DS_Store

# Editor
.vscode/
.idea/
*.swp
